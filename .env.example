# Optionele API-sleutels (de app werkt ook zonder)
CRYPTOCOMPARE_API_KEY=your_key_here   # Gratis op cryptocompare.com

# Server instellingen
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
DATABASE_URL=sqlite:///./crypto_monitor.db

# Update intervallen (in seconden)
COIN_UPDATE_INTERVAL=300    # 5 minuten
NEWS_UPDATE_INTERVAL=900    # 15 minuten
